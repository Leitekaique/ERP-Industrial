# ================================
# 🌍 Ambiente e Aplicação
# ================================
NODE_ENV=development
PORT=3000

# ================================
# 🗃️ Banco de Dados
# ================================
DATABASE_URL=postgresql://postgres:postgres@db:5432/erp?schema=public

# ================================
# 🧩 Prisma
# ================================
PRISMA_CLI_BINARY_TARGETS=debian-openssl-3.0.x,windows,linux-musl
PRISMA_GENERATE_SKIP_DOWNLOAD=true
PRISMA_CLI_QUERY_ENGINE_TYPE=library
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1
PRISMA_LOG_LEVEL=info
PRISMA_HIDE_UPDATE_MESSAGE=true

# ================================
# ⚙️ Configurações do ERP
# ================================
DEFAULT_TENANT_ID=T-001
DEFAULT_COMPANY_ID=C-001

# ================================
# 🔐 Autenticação
# ================================
JWT_SECRET=troque-por-uma-chave-segura-em-producao
JWT_EXPIRES_IN=24h

# ================================
# 📡 SEFAZ / NF-e
# ================================
# Modos disponíveis:
#   simulator   → sem certificado, resposta simulada (DEV/testes)
#   homologacao → SEFAZ homologação, certificado obrigatório
#   producao    → SEFAZ produção, certificado obrigatório
SEFAZ_ENV=simulator
SEFAZ_UF=35

# Certificado A1 — necessário apenas em homologacao/producao
# CERT_PATH=/caminho/para/certificado.pfx
CERT_PASSWORD=

# ================================
# 📧 E-mail / SMTP
# ================================
# MAIL_ENABLED=false → nenhum e-mail é enviado (dev/testes)
# MAIL_ENABLED=true  → envio real via SMTP
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-gmail
SMTP_FROM=Nome Empresa <seu-email@gmail.com>

# ================================
# 📊 IBPT — Tributos Aproximados (Lei 12.741/2012)
# ================================
# Token para atualização automática das alíquotas via iws.ibpt.org.br
# Sem token: usa valores padrão (Federal 13,45% + Estadual 18,00%)
# Para obter: acesse https://iws.ibpt.org.br → Cadastre-se → copie o Token
# IBPT_TOKEN=seu_token_aqui
# IBPT_NCM=5903    # NCM do produto (padrão: 5903 — tecidos impregnados)
# IBPT_UF=SP       # UF para alíquota estadual

# ================================
# 🧠 Frontend
# ================================
VITE_API_URL=http://localhost:3000
